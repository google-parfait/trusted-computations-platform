# Add target_compatible_with to the list of gcc_toolchains.toolchain attributes.
--- toolchain/defs.bzl
+++ toolchain/defs.bzl
@@ -382,4 +382,4 @@
 ATTRS_SHARED_WITH_MODULE_EXTENSION = {
     attr_name: _FEATURE_ATTRS[attr_name]
-    for attr_name in ["gcc_version", "gcc_versions", "extra_cflags", "extra_cxxflags", "extra_ldflags", "extra_fflags", "extra_asmflags"]
+    for attr_name in ["target_compatible_with", "gcc_version", "gcc_versions", "extra_cflags", "extra_cxxflags", "extra_ldflags", "extra_fflags", "extra_asmflags"]
 }

--- toolchain/module_extensions.bzl
+++ toolchain/module_extensions.bzl
@@ -12,3 +12,4 @@
         for declare in mod.tags.toolchain:
             gcc_declare_toolchain(
+                target_compatible_with = declare.target_compatible_with,
                 name = declare.name,
